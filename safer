#!/bin/sh

safer_ver=0.0-dev

safer_usage="Usage:
$0 [[OPTIONS] [<cmd> <image> [dir...]]]

Arguments:
 cmd         Name of the tool executable.
 image       Image where the tool executable resides.
 dir         Extra directories to mount in the container.

For the full list of Options and Environment Vars, see the man page.

Options:
 -e          Tool entrypoint in the image.
 -p          Port to expose (e.g., 8080 or 80:8080).
 -k          Run the tool in a persistent container.
 -n          Use this name to persist the container (implies -k).
 -f          Force script replacement.
 -s          Skip container pseudo-tty allocation.
 -l          Get the tool definition from the library.
 -i          Install a Containerfile from the library.
 -v          Display the current version.
 -h          Display usage and exit.

Environment Vars:
 SAFER_DIR      Directory for the scripts. Default .safer .

Config files: /etc/safer, ~/.saferrc, .saferrc"

# Section 1: Init safer and read args/env

[ -e "/etc/safer" ] && . "/etc/safer"
[ -e "$HOME/.saferrc" ] && . "$HOME/.saferrc"
[ -e ".saferrc" ] && . ".saferrc"

safer_dir=${SAFER_DIR:-.safer}
safer_lib_path=${SAFER_LIB_PATH:-~/.local/share/safer:/usr/share/safer:/usr/local/share/safer}
safer_inf_cmd="${SAFER_PERSIST_CMD:-sleep inf}"
safer_inf_stop_cmd="${SAFER_PERSIST_STOP_CMD:---safer-stop}"

while getopts e:p:kn:d:R:X:K:S:fslivh opt
do
	case $opt in
		e) safer_entrypoint=$OPTARG ;;
		p) safer_port=$OPTARG ;;
		k) safer_persist=1 ;;
		n) safer_cname=$OPTARG ;;
		d) safer_dir=$OPTARG ;;
		R) safer_runtime_cmd=$OPTARG ;;
		X) safer_opts_runtime_args=$OPTARG ;;
		K) safer_inf_cmd=$OPTARG ;;
		S) safer_inf_stop_cmd=$OPTARG ;;
		f) safer_force=1 ;;
		s) safer_skip_tty=1 ;;
		l) safer_lib_tool=1 ;;
		i) safer_lib_image=1 ;;
		v) echo $safer_ver && exit ;;
		h) echo "$safer_usage" && exit ;;
		*) ;;
	esac
done

shift $((OPTIND - 1))

# Section 2: Library commands

if [ $# -gt 0 ] && [ "${safer_lib_tool+x}" ] || [ "${safer_lib_image+x}" ]; then
	safer_lib_item="$1"
	shift 1
	if [ "${safer_lib_tool+x}" ]; then
		echo "$safer_lib_path" | while IFS=":" read -r location; do
			if [ -e "$location/tools/$safer_lib_item" ]; then
				sh "$location/tools/$safer_lib_item" "$@"
				break
			fi
		done
	fi
	mkdir -p "$safer_dir/build"
	if [ "${safer_lib_image+x}" ]; then
		echo "$safer_lib_path" | while IFS=":" read -r location; do
			if [ -e "$location/images/$safer_lib_item" ]; then
				if [ -e "$safer_dir/build/$safer_lib_item" ]; then
					echo "$safer_dir/build/$safer_lib_item already exists."
					exit 1
				else
					cp "$location/images/$safer_lib_item" "$safer_dir/build/$safer_lib_item"
					break
				fi
			fi
		done
		if [ ! -e "$safer_dir/build/$safer_lib_item" ]; then
			echo "$safer_lib_item image not found in library."
			exit 1
		fi
	fi
	exit
fi

# Section 3: Non-library execution, PATH definition and bad args exit

if [ $# -gt 1 ]; then
	safer_cmd="$1"
	safer_image="$2"
	shift 2
elif [ $# -eq 0 ]; then
	printf 'PATH="%s:$PATH"\n' "$safer_dir"
	exit
else
	echo "$safer_usage"
	exit 1
fi

# Section 4: Simple pre-processing of vars

script_dest="$safer_dir/$safer_cmd"
if [ -e "$script_dest" ] && [ -z "$safer_force" ]; then
	echo "$script_dest already exists."
	exit 1
fi

if [ -n "$safer_port" ]; then
	case "$safer_port" in
		*:*) safer_port_map="$safer_port" ;;
		*) safer_port_map="$safer_port:$safer_port" ;;
	esac
fi

if [ "${safer_persist+x}" ] && [ -z "$safer_cname" ]; then
	safer_cname_dir="$(echo "${PWD##*/}" | tr -cd '[:alnum:]')"
	safer_cname="$safer_cmd-$safer_cname_dir"
fi

if [ -z "${safer_runtime_cmd:=$SAFER_RT_CMD}" ]; then
	if command -v podman >/dev/null 2>&1; then
		safer_runtime_cmd=podman
	elif command -v docker >/dev/null 2>&1; then
		safer_runtime_cmd=docker
	else
		echo "Cannot detect a container runtime. See man page for more info."
		exit 1
	fi
fi

if [ "${safer_opts_runtime_args+x}" ]; then
	safer_runtime_args="$safer_opts_runtime_args"
elif [ "${SAFER_RT_ARGS+x}" ]; then
	safer_runtime_args="$SAFER_RT_ARGS"
elif [ "$safer_runtime_cmd" = "docker" ] || [ "$safer_runtime_cmd" = "sudo docker" ]; then
	safer_runtime_args='--user "$(id -u):$(id -g)"'
fi

# Section 5: Preprocessing of the original entrypoint parts

if [ -n "$safer_cname" ]; then
	pad='\t'  # indent the original run lines on persistent scripts
fi

# Freeing $@
extra_volumes=
for arg in "$@"; do
	next_volume=$(printf ' \\\n%b\t-v "%s":"%s"' "$pad" "$arg" "$arg")
	extra_volumes=$extra_volumes$next_volume
done

# Capture original image entrypoint and args
if [ -n "$safer_cname" ] && [ -z "$safer_entrypoint" ]; then
	set -f
	IFS='
'
	# shellcheck disable=SC2046
	set -- $(
		$safer_runtime_cmd image inspect \
		--format '{{range .Config.Entrypoint}}{{println .}}{{end}}' \
		"$safer_image"
	)
	unset IFS

	if [ $# -gt 0 ]; then
		og_entrypoint=$1
		shift

		for arg in "$@"; do
			og_exec_args=$og_exec_args$(
				printf "'%s' " "$(printf "%s" "$arg" | sed "s/'/'\\\\''/g")"
			)
		done
		[ -n "$og_exec_args" ] && og_exec_args=${og_exec_args%?}
	fi
fi

# Section 6: Writing the script

script_file=$(mktemp)
cwd=$(pwd -P)

interactive_flag=-ti
[ "${safer_skip_tty+x}" ] && interactive_flag=-i

{
	printf '#!/bin/sh\n'

	printf 'project_dir="%s"\n' "$cwd"
	printf 'case "$(pwd -P)/" in\n'
	printf '\t"$project_dir/"*) ;;\n'
	printf '\t*) echo "safer: $0: outside project dir" 2>&1; exit 1 ;;\n'
	printf 'esac\n'

	if [ -n "$safer_cname" ]; then
		printf 'if [ "$*" = "%s" ]; then\n' "$safer_inf_stop_cmd"
		printf '\t%s kill %s\n' "$safer_runtime_cmd" "$safer_cname"
		printf '\texit\n'
		printf 'fi\n'
		printf 'if ! %s container inspect %s >/dev/null 2>&1; then\n' "$safer_runtime_cmd" "$safer_cname"
	fi

	if [ -n "$safer_cname" ]; then
		printf '\t%s run --rm \\\n' "$safer_runtime_cmd"
	else
		printf '%s run --rm %s \\\n' "$safer_runtime_cmd" "$interactive_flag"
	fi

	if [ -n "$safer_runtime_args" ]; then
		printf '%b\t%s \\\n' "$pad" "$safer_runtime_args"
	fi

	if [ -n "$safer_cname" ]; then
		printf '\t\t--entrypoint '\'''\'' \\\n'
	elif [ -n "$safer_entrypoint" ]; then
		printf '\t--entrypoint '\''%s'\'' \\\n' "$safer_entrypoint"
	fi

	if [ -n "$safer_port_map" ]; then
		printf '%b\t-p "%s" \\\n' "$pad" "$safer_port_map"
	fi

	printf '%b\t-v "%s":"%s" \\\n' "$pad" "$cwd" "$cwd"

	if [ -n "$safer_cname" ]; then
		printf '\t\t-w "$project_dir"'
	else
		printf '\t-w "$(pwd -P)"'
	fi

	printf '%s' "$extra_volumes"

	if [ -n "$safer_cname" ]; then
		printf ' \\\n\t\t-d --name "%s" \\\n' "$safer_cname"
	else
		printf ' \\\n'
	fi

	if [ -n "$safer_cname" ]; then
		printf '\t\t%s %s\n' "$safer_image" "$safer_inf_cmd"
	else
		printf '\t%s "$@"\n' "$safer_image"
	fi

	if [ -n "$safer_cname" ]; then
		printf 'fi\n'
		printf '%s exec %s \\\n' "$safer_runtime_cmd" "$interactive_flag"
		if [ -n "$safer_runtime_args" ]; then
			printf '\t%s \\\n' "$safer_runtime_args"
		fi
		printf '\t-w "$(pwd -P)" \\\n'
		if [ -n "$safer_entrypoint" ]; then
			printf '\t%s '\''%s'\'' "$@"\n' "$safer_cname" "$safer_entrypoint"
		else
			if [ -z "$og_entrypoint" ]; then
				printf '\t%s "$@"\n' "$safer_cname"
			elif [ -z "$og_exec_args" ]; then
				printf '\t%s '\''%s'\'' "$@"\n' "$safer_cname" "$og_entrypoint"
			else
				printf '\t%s '\''%s'\'' %s "$@"\n' "$safer_cname" "$og_entrypoint" "$og_exec_args"
			fi
		fi
	fi

} > "$script_file"

install -D "$script_file" "$script_dest"
rm -f "$script_file"
