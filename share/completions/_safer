  '-e[Tool entrypoint in the image]' \
  '-p[Port to expose]' \
  '-k[Run the tool in a persistent container]' \
  '-n[Use this name to persist the container]' \
  '-d[Directory for the scripts]' \
  '-R[Runtime cli command. Override podman/docker detection]' \
